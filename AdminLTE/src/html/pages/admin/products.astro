---
import Head from "@components/_head.astro"
import Footer from "@components/dashboard/_footer.astro"
import Topbar from "@components/dashboard/_topbar.astro"
import Sidenav from "@components/dashboard/_sidenav.astro"
import Scripts from "@components/_scripts.astro"

const title = "Think Tank | Quản lý Sản phẩm"
const path = "../dist"
const mainPage = "admin"
const page = "products"
---

<!doctype html>
<html lang="en">
  <!--begin::Head-->
  <head>
    <Head title={title} path={path} />
    <script is:inline>
      // Auth Guard
      if (!localStorage.getItem("admin_token")) {
        window.location.href = "./login.html";
      }
    </script>
  </head>
  <!--end::Head-->
  <!--begin::Body-->
  <body class="layout-fixed sidebar-expand-lg bg-body-tertiary">
    <!--begin::App Wrapper-->
    <div class="app-wrapper">
      <Topbar path={path} />
      <Sidenav path={path} mainPage={mainPage} page={page} />
      <!--begin::App Main-->
      <main class="app-main">
        <!--begin::App Content Header-->
        <div class="app-content-header">
          <div class="container-fluid">
            <div class="row">
              <div class="col-sm-6">
                <h3 class="mb-0">Quản lý Sản phẩm</h3>
              </div>
              <div class="col-sm-6">
                <ol class="breadcrumb float-sm-end">
                  <li class="breadcrumb-item"><a href="./index.html">Admin</a></li>
                  <li class="breadcrumb-item active" aria-current="page">Sản phẩm</li>
                </ol>
              </div>
            </div>
          </div>
        </div>
        <!--end::App Content Header-->
        <!--begin::App Content-->
        <div class="app-content">
          <div class="container-fluid">
            <!-- Alert message -->
            <div id="alert-box" class="alert alert-dismissible fade show d-none" role="alert">
              <span id="alert-message"></span>
              <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>

            <!-- Filters & Actions -->
            <div class="card mb-4 shadow-sm border-0">
              <div class="card-body">
                <div class="row g-3 align-items-center">
                  <div class="col-md-4">
                    <div class="input-group">
                      <span class="input-group-text bg-transparent border-end-0 text-muted">
                        <i class="bi bi-search"></i>
                      </span>
                      <input
                        type="text"
                        id="filter-search"
                        class="form-control border-start-0"
                        placeholder="Tìm kiếm sản phẩm theo tên..."
                      />
                    </div>
                  </div>
                  <div class="col-md-3">
                    <select id="filter-category" class="form-select">
                      <option value="">Tất cả danh mục</option>
                    </select>
                  </div>
                  <div class="col-md-3">
                    <button id="btn-search-trigger" class="btn btn-primary px-4">
                      <i class="bi bi-funnel-fill"></i> Lọc
                    </button>
                    <button id="btn-reset-trigger" class="btn btn-outline-secondary ms-2">
                      Làm mới
                    </button>
                  </div>
                  <div class="col-md-2 text-md-end">
                    <button id="btn-add-product" class="btn btn-success w-100" data-bs-toggle="modal" data-bs-target="#productModal">
                      <i class="bi bi-plus-lg"></i> Thêm mới
                    </button>
                  </div>
                </div>
              </div>
            </div>

            <!-- Products List Table -->
            <div class="card shadow-sm border-0 mb-4">
              <div class="card-body p-0">
                <div class="table-responsive">
                  <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                      <tr>
                        <th width="80">Ảnh</th>
                        <th>Thông tin sản phẩm</th>
                        <th>Danh mục</th>
                        <th>SKU</th>
                        <th class="text-end">Giá bán</th>
                        <th class="text-center">Kho</th>
                        <th class="text-center">Số phiên bản</th>
                        <th class="text-end" width="150">Hành động</th>
                      </tr>
                    </thead>
                    <tbody id="products-table-body">
                      <tr>
                        <td colspan="8" class="text-center py-5 text-muted">
                          <div class="spinner-border spinner-border-sm text-primary me-2" role="status"></div>
                          Đang tải danh sách sản phẩm...
                        </td>
                      </tr>
                    </tbody>
                  </table>
                </div>
              </div>
              <div class="card-footer bg-transparent border-top-0 d-flex justify-content-between align-items-center py-3">
                <div class="text-muted small" id="pagination-info">
                  Hiển thị 0–0 trên tổng số 0 sản phẩm
                </div>
                <nav aria-label="Pagination">
                  <ul class="pagination pagination-sm mb-0" id="pagination-ul">
                    <!-- Pagination pages go here -->
                  </ul>
                </nav>
              </div>
            </div>

          </div>
        </div>
        <!--end::App Content-->
      </main>
      <!--end::App Main-->

      <!--begin::Product Modal-->
      <div class="modal fade" id="productModal" tabindex="-1" aria-labelledby="productModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-lg modal-dialog-scrollable">
          <div class="modal-content">
            <form id="product-form">
              <div class="modal-header">
                <h5 class="modal-title fw-bold" id="productModalLabel">Thêm sản phẩm mới</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
              </div>
              <div class="modal-body">
                <input type="hidden" id="product-id" />
                
                <div class="row g-3">
                  <!-- Product Name -->
                  <div class="col-md-8">
                    <label for="p-name" class="form-label fw-bold">Tên sản phẩm *</label>
                    <input type="text" id="p-name" class="form-control" required />
                  </div>
                  <!-- Category -->
                  <div class="col-md-4">
                    <label for="p-category" class="form-label fw-bold">Danh mục *</label>
                    <select id="p-category" class="form-select" required>
                      <option value="">Chọn danh mục</option>
                    </select>
                  </div>

                  <!-- Price & Stock -->
                  <div class="col-md-4">
                    <label for="p-price" class="form-label fw-bold">Giá bán chính thức (đ) *</label>
                    <input type="number" id="p-price" class="form-control" min="0" required />
                  </div>
                  <div class="col-md-4">
                    <label for="p-stock" class="form-label fw-bold">Số lượng trong kho *</label>
                    <input type="number" id="p-stock" class="form-control" min="0" required />
                  </div>
                  <div class="col-md-4">
                    <label for="p-sku" class="form-label fw-bold">SKU chính *</label>
                    <input type="text" id="p-sku" class="form-control" required placeholder="Ví dụ: TT-AIRPORT-ACC" />
                  </div>

                  <!-- Image URL -->
                  <div class="col-12">
                    <label for="p-imageUrl" class="form-label fw-bold">Ảnh sản phẩm (URL) *</label>
                    <input type="url" id="p-imageUrl" class="form-control" required placeholder="https://..." />
                  </div>

                  <!-- Tech Specs -->
                  <div class="col-md-3">
                    <label for="p-weight" class="form-label fw-bold small text-secondary">Trọng lượng</label>
                    <input type="text" id="p-weight" class="form-control" placeholder="1.5 kg" />
                  </div>
                  <div class="col-md-3">
                    <label for="p-volume" class="form-label fw-bold small text-secondary">Thể tích</label>
                    <input type="text" id="p-volume" class="form-control" placeholder="20L" />
                  </div>
                  <div class="col-md-3">
                    <label for="p-dimensions" class="form-label fw-bold small text-secondary">Kích thước</label>
                    <input type="text" id="p-dimensions" class="form-control" placeholder="32 x 45 x 18 cm" />
                  </div>
                  <div class="col-md-3">
                    <label for="p-material" class="form-label fw-bold small text-secondary">Chất liệu</label>
                    <input type="text" id="p-material" class="form-control" placeholder="Nylon Ballistic" />
                  </div>

                  <!-- Description -->
                  <div class="col-12">
                    <label for="p-description" class="form-label fw-bold">Mô tả sản phẩm</label>
                    <textarea id="p-description" class="form-control" rows="4"></textarea>
                  </div>
                </div>

                <!-- Variants management -->
                <div class="border-top mt-4 pt-3">
                  <div class="d-flex justify-between align-items-center mb-3">
                    <h6 class="fw-bold text-primary mb-0"><i class="bi bi-tags-fill"></i> Các phiên bản thuộc tính (Màu sắc / Kích thước)</h6>
                    <button type="button" id="btn-add-variant" class="btn btn-sm btn-outline-primary">
                      <i class="bi bi-plus-lg"></i> Thêm phiên bản
                    </button>
                  </div>

                  <div class="table-responsive">
                    <table class="table table-bordered align-middle table-sm">
                      <thead class="table-light">
                        <tr>
                          <th>SKU phiên bản</th>
                          <th>Tên phiên bản</th>
                          <th>Màu sắc</th>
                          <th>Kích thước</th>
                          <th>Giá bán (đ)</th>
                          <th>Kho</th>
                          <th class="text-center" width="50">Xóa</th>
                        </tr>
                      </thead>
                      <tbody id="variants-tbody">
                        <!-- Variant rows go here -->
                      </tbody>
                    </table>
                    <div id="variants-empty-message" class="text-muted text-center py-2 bg-light small rounded">
                      Chưa có thuộc tính phiên bản riêng biệt. Sản phẩm sẽ được bán theo các thông số chung ở trên.
                    </div>
                  </div>
                </div>
              </div>
              <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button>
                <button type="submit" class="btn btn-primary" id="btn-save-product">Lưu sản phẩm</button>
              </div>
            </form>
          </div>
        </div>
      </div>
      <!--end::Product Modal-->

      <!--Delete Confirmation Modal-->
      <div class="modal fade" id="deleteConfirmModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog">
          <div class="modal-content">
            <div class="modal-header">
              <h5 class="modal-title fw-bold">Xác nhận xóa</h5>
              <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
              Bạn có chắc chắn muốn xóa sản phẩm <strong id="delete-product-name" class="text-danger"></strong>? Hành động này không thể hoàn tác!
            </div>
            <div class="modal-footer">
              <button type="button" class="btn id-close btn-secondary" data-bs-dismiss="modal">Đóng</button>
              <button type="button" class="btn btn-danger" id="btn-confirm-delete">Xóa vĩnh viễn</button>
            </div>
          </div>
        </div>
      </div>
      <!--end::Delete Confirmation Modal-->

      <Footer />
    </div>
    <!--end::App Wrapper-->

    <!--begin::Script-->
    <Scripts path={path} />

    <script is:inline>
      document.addEventListener("DOMContentLoaded", async () => {
        const token = localStorage.getItem("admin_token");
        const BASE_URL = window.location.hostname === "localhost" || window.location.hostname === "127.0.0.1" 
          ? "http://localhost:8080" 
          : "";

        const headers = {
          "Authorization": `Bearer ${token}`,
          "Content-Type": "application/json"
        };

        // State vars
        let categories = [];
        let currentPage = 0;
        const limit = 10;
        let deleteId = null;

        // Bootstrap instances
        let productModal = null;
        let deleteModal = null;

        if (typeof bootstrap !== 'undefined') {
          productModal = new bootstrap.Modal(document.getElementById('productModal'));
          deleteModal = new bootstrap.Modal(document.getElementById('deleteConfirmModal'));
        }

        // 1. Fetch and Populate Categories
        async function loadCategories() {
          try {
            const res = await fetch(`${BASE_URL}/api/categories`, { headers });
            categories = await res.json();
            
            // Populate filters
            const filterCat = document.getElementById("filter-category");
            const formCat = document.getElementById("p-category");
            
            filterCat.innerHTML = `<option value="">Tất cả danh mục</option>`;
            formCat.innerHTML = `<option value="">Chọn danh mục</option>`;

            categories.forEach(cat => {
              filterCat.innerHTML += `<option value="${cat.id}">${cat.name}</option>`;
              formCat.innerHTML += `<option value="${cat.id}">${cat.name}</option>`;
            });
          } catch (err) {
            console.error("Lỗi tải danh mục:", err);
          }
        }

        // 2. Fetch and Render Products Table
        async function fetchProducts(pageNo = 0) {
          currentPage = pageNo;
          const search = document.getElementById("filter-search").value.trim();
          const categoryId = document.getElementById("filter-category").value;

          const query = new URLSearchParams();
          query.append("page", pageNo);
          query.append("limit", limit);
          if (search) query.append("search", search);
          if (categoryId) query.append("categoryId", categoryId);

          const tbody = document.getElementById("products-table-body");
          tbody.innerHTML = `
            <tr>
              <td colspan="8" class="text-center py-5 text-muted">
                <div class="spinner-border spinner-border-sm text-primary me-2" role="status"></div>
                Đang tải danh sách sản phẩm...
              </td>
            </tr>
          `;

          try {
            const res = await fetch(`${BASE_URL}/api/products?${query.toString()}`, { headers });
            const pageData = await res.json();
            
            tbody.innerHTML = "";

            if (!pageData.content || pageData.content.length === 0) {
              tbody.innerHTML = `<tr><td colspan="8" class="text-center py-5 text-muted">Không tìm thấy sản phẩm nào!</td></tr>`;
              document.getElementById("pagination-info").textContent = "Hiển thị 0–0 trên 0 sản phẩm";
              document.getElementById("pagination-ul").innerHTML = "";
              return;
            }

            pageData.content.forEach(p => {
              const categoryName = p.category ? p.category.name : "Chưa có";
              const varCount = p.variants ? p.variants.length : 0;
              
              const tr = document.createElement("tr");
              tr.innerHTML = `
                <td>
                  <img src="${p.imageUrl || 'https://placehold.co/80'}" alt="${p.name}" class="img-thumbnail rounded" style="width: 50px; height: 50px; object-fit: contain;" />
                </td>
                <td>
                  <div class="fw-bold text-dark">${p.name}</div>
                  <div class="text-muted small">${p.description ? p.description.substring(0, 70) + '...' : 'Không có mô tả'}</div>
                </td>
                <td><span class="badge bg-light text-dark border">${categoryName}</span></td>
                <td><code class="text-secondary">${p.sku || 'N/A'}</code></td>
                <td class="text-end fw-bold text-primary">${p.price.toLocaleString("vi-VN")}đ</td>
                <td class="text-center font-monospace">${p.stock}</td>
                <td class="text-center"><span class="badge bg-info text-white rounded-pill">${varCount}</span></td>
                <td class="text-end">
                  <button class="btn btn-sm btn-outline-primary me-1 btn-edit" data-id="${p.id}"><i class="bi bi-pencil"></i> Sửa</button>
                  <button class="btn btn-sm btn-outline-danger btn-delete" data-id="${p.id}" data-name="${p.name}"><i class="bi bi-trash"></i> Xóa</button>
                </td>
              `;
              tbody.appendChild(tr);
            });

            // Update Pagination info
            const start = pageNo * limit + 1;
            const end = Math.min((pageNo + 1) * limit, pageData.totalElements);
            document.getElementById("pagination-info").textContent = `Hiển thị ${start}–${end} trên tổng số ${pageData.totalElements} sản phẩm`;

            // Draw Pagination buttons
            renderPagination(pageData.totalPages, pageNo);

          } catch (err) {
            console.error("Lỗi đồng bộ sản phẩm:", err);
            tbody.innerHTML = `<tr><td colspan="8" class="text-center py-5 text-danger fw-bold">Không kết nối được với Server!</td></tr>`;
          }
        }

        // Render Pagination buttons
        function renderPagination(totalPages, activePage) {
          const ul = document.getElementById("pagination-ul");
          ul.innerHTML = "";

          // Prev button
          const prevLi = document.createElement("li");
          prevLi.className = `page-item ${activePage === 0 ? 'disabled' : ''}`;
          prevLi.innerHTML = `<a class="page-link" href="#" data-page="${activePage - 1}">&laquo;</a>`;
          ul.appendChild(prevLi);

          // Page items
          for (let i = 0; i < totalPages; i++) {
            const pageLi = document.createElement("li");
            pageLi.className = `page-item ${i === activePage ? 'active' : ''}`;
            pageLi.innerHTML = `<a class="page-link" href="#" data-page="${i}">${i + 1}</a>`;
            ul.appendChild(pageLi);
          }

          // Next button
          const nextLi = document.createElement("li");
          nextLi.className = `page-item ${activePage === totalPages - 1 || totalPages === 0 ? 'disabled' : ''}`;
          nextLi.innerHTML = `<a class="page-link" href="#" data-page="${activePage + 1}">&raquo;</a>`;
          ul.appendChild(nextLi);

          // Click handler
          ul.querySelectorAll("a").forEach(a => {
            a.addEventListener("click", (e) => {
              e.preventDefault();
              const p = parseInt(e.target.getAttribute("data-page"));
              if (!isNaN(p) && p >= 0 && p < totalPages) {
                fetchProducts(p);
              }
            });
          });
        }

        // Alert Helper
        function showAlert(msg, type = "success") {
          const alertBox = document.getElementById("alert-box");
          const alertMsg = document.getElementById("alert-message");
          alertBox.className = `alert alert-${type} alert-dismissible fade show`;
          alertMsg.textContent = msg;
          alertBox.classList.remove("d-none");
          setTimeout(() => {
            alertBox.classList.add("d-none");
          }, 4000);
        }

        // 3. Variant management row addition
        const variantsTbody = document.getElementById("variants-tbody");
        const emptyMsg = document.getElementById("variants-empty-message");

        function addVariantRow(variantData = {}) {
          emptyMsg.classList.add("d-none");
          const tr = document.createElement("tr");
          tr.className = "variant-row";
          
          tr.innerHTML = `
            <td>
              <input type="hidden" class="var-id" value="${variantData.id || ''}" />
              <input type="text" class="form-control form-control-sm var-sku" value="${variantData.sku || ''}" required placeholder="SKU" />
            </td>
            <td>
              <input type="text" class="form-control form-control-sm var-name" value="${variantData.name || ''}" required placeholder="Tên" />
            </td>
            <td>
              <input type="text" class="form-control form-control-sm var-color" value="${variantData.color || ''}" placeholder="Đen, Xám..." />
            </td>
            <td>
              <input type="text" class="form-control form-control-sm var-size" value="${variantData.size || ''}" placeholder="S, M, L..." />
            </td>
            <td>
              <input type="number" class="form-control form-control-sm var-price" value="${variantData.price || ''}" min="0" required placeholder="Giá" />
            </td>
            <td>
              <input type="number" class="form-control form-control-sm var-stock" value="${variantData.stock !== undefined ? variantData.stock : ''}" min="0" required placeholder="Kho" />
            </td>
            <td class="text-center">
              <button type="button" class="btn btn-sm btn-outline-danger btn-remove-var-row py-0 px-2">✕</button>
            </td>
          `;
          
          tr.querySelector(".btn-remove-var-row").addEventListener("click", () => {
            tr.remove();
            if (variantsTbody.querySelectorAll(".variant-row").length === 0) {
              emptyMsg.classList.remove("d-none");
            }
          });

          variantsTbody.appendChild(tr);
        }

        document.getElementById("btn-add-variant").addEventListener("click", () => {
          // Prefill variant SKU based on parent SKU if available
          const parentSku = document.getElementById("p-sku").value.trim();
          const pName = document.getElementById("p-name").value.trim();
          const pPrice = document.getElementById("p-price").value;
          const varCount = variantsTbody.querySelectorAll(".variant-row").length + 1;
          
          addVariantRow({
            sku: parentSku ? `${parentSku}-V${varCount}` : "",
            name: pName ? `${pName} - Bản ${varCount}` : "",
            price: pPrice || 0,
            stock: 10
          });
        });

        // 4. Submit Create/Edit Product Form
        document.getElementById("product-form").addEventListener("submit", async (e) => {
          e.preventDefault();

          const prodId = document.getElementById("product-id").value;
          
          // Gather variants
          const variantRows = variantsTbody.querySelectorAll(".variant-row");
          const variantsList = [];
          variantRows.forEach(row => {
            const vId = row.querySelector(".var-id").value;
            variantsList.push({
              id: vId ? parseInt(vId) : null,
              sku: row.querySelector(".var-sku").value.trim(),
              name: row.querySelector(".var-name").value.trim(),
              color: row.querySelector(".var-color").value.trim(),
              size: row.querySelector(".var-size").value.trim(),
              price: parseFloat(row.querySelector(".var-price").value),
              stock: parseInt(row.querySelector(".var-stock").value)
            });
          });

          const productPayload = {
            name: document.getElementById("p-name").value.trim(),
            categoryId: parseInt(document.getElementById("p-category").value),
            price: parseFloat(document.getElementById("p-price").value),
            stock: parseInt(document.getElementById("p-stock").value),
            sku: document.getElementById("p-sku").value.trim(),
            imageUrl: document.getElementById("p-imageUrl").value.trim(),
            description: document.getElementById("p-description").value.trim(),
            weight: document.getElementById("p-weight").value.trim(),
            volume: document.getElementById("p-volume").value.trim(),
            dimensions: document.getElementById("p-dimensions").value.trim(),
            material: document.getElementById("p-material").value.trim(),
            additionalImages: [],
            variants: variantsList
          };

          const method = prodId ? "PUT" : "POST";
          const url = prodId ? `${BASE_URL}/api/admin/products/${prodId}` : `${BASE_URL}/api/admin/products`;

          try {
            const saveRes = await fetch(url, {
              method,
              headers,
              body: JSON.stringify(productPayload)
            });

            if (!saveRes.ok) {
              throw new Error("Lỗi khi lưu sản phẩm!");
            }

            productModal.hide();
            showAlert(prodId ? "Đã cập nhật sản phẩm thành công!" : "Đã tạo sản phẩm mới thành công!");
            fetchProducts(currentPage);
          } catch (err) {
            alert(err.message);
          }
        });

        // 5. Open Modal for Create
        document.getElementById("btn-add-product").addEventListener("click", () => {
          document.getElementById("productModalLabel").textContent = "Thêm sản phẩm mới";
          document.getElementById("product-id").value = "";
          document.getElementById("product-form").reset();
          variantsTbody.innerHTML = "";
          emptyMsg.classList.remove("d-none");
        });

        // 6. Open Modal for Edit
        document.getElementById("products-table-body").addEventListener("click", async (e) => {
          const btnEdit = e.target.closest(".btn-edit");
          const btnDelete = e.target.closest(".btn-delete");

          if (btnEdit) {
            const id = btnEdit.getAttribute("data-id");
            try {
              const res = await fetch(`${BASE_URL}/api/products/${id}`, { headers });
              if (!res.ok) throw new Error("Không thể tải thông tin sản phẩm");
              
              const p = await res.json();
              
              document.getElementById("productModalLabel").textContent = `Chỉnh sửa sản phẩm: ${p.name}`;
              document.getElementById("product-id").value = p.id;
              
              document.getElementById("p-name").value = p.name || "";
              document.getElementById("p-category").value = p.category ? p.category.id : "";
              document.getElementById("p-price").value = p.price || 0;
              document.getElementById("p-stock").value = p.stock || 0;
              document.getElementById("p-sku").value = p.sku || "";
              document.getElementById("p-imageUrl").value = p.imageUrl || "";
              document.getElementById("p-description").value = p.description || "";
              
              document.getElementById("p-weight").value = p.weight || "";
              document.getElementById("p-volume").value = p.volume || "";
              document.getElementById("p-dimensions").value = p.dimensions || "";
              document.getElementById("p-material").value = p.material || "";

              // Load variants
              variantsTbody.innerHTML = "";
              if (p.variants && p.variants.length > 0) {
                emptyMsg.classList.add("d-none");
                p.variants.forEach(v => addVariantRow(v));
              } else {
                emptyMsg.classList.remove("d-none");
              }

              productModal.show();
            } catch (err) {
              alert(err.message);
            }
          }

          if (btnDelete) {
            deleteId = btnDelete.getAttribute("data-id");
            const name = btnDelete.getAttribute("data-name");
            document.getElementById("delete-product-name").textContent = name;
            deleteModal.show();
          }
        });

        // 7. Confirm Delete Product
        document.getElementById("btn-confirm-delete").addEventListener("click", async () => {
          if (!deleteId) return;
          try {
            const delRes = await fetch(`${BASE_URL}/api/admin/products/${deleteId}`, {
              method: "DELETE",
              headers
            });

            if (!delRes.ok) {
              throw new Error("Lỗi khi xóa sản phẩm!");
            }

            deleteModal.hide();
            showAlert("Đã xóa sản phẩm thành công!", "danger");
            fetchProducts(currentPage);
          } catch (err) {
            alert(err.message);
          }
        });

        // Filters Search / Reset
        document.getElementById("btn-search-trigger").addEventListener("click", () => {
          fetchProducts(0);
        });

        document.getElementById("btn-reset-trigger").addEventListener("click", () => {
          document.getElementById("filter-search").value = "";
          document.getElementById("filter-category").value = "";
          fetchProducts(0);
        });

        // Bootstrap load and setup
        await loadCategories();
        await fetchProducts(0);
      });
    </script>
  </body><!--end::Body-->
</html>
