---
import Head from "@components/_head.astro"
import Footer from "@components/dashboard/_footer.astro"
import Topbar from "@components/dashboard/_topbar.astro"
import Sidenav from "@components/dashboard/_sidenav.astro"
import Scripts from "@components/_scripts.astro"

const title = "Think Tank | Báo cáo Thống kê"
const path = "../dist"
const mainPage = "admin"
const page = "dashboard"
---

<!doctype html>
<html lang="en">
  <!--begin::Head-->
  <head>
    <Head title={title} path={path} />

    <!-- apexcharts -->
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/apexcharts@3.37.1/dist/apexcharts.css"
      integrity="sha256-4MX+61mt9NVvvuPjUWdUdyfZfxSB1/Rf9WtqRHgG5S0="
      crossorigin="anonymous"
    />
    <script is:inline>
      // Auth Guard
      if (!localStorage.getItem("admin_token")) {
        window.location.href = "./login.html";
      }
    </script>
  </head>
  <!--end::Head-->
  <!--begin::Body-->
  <body class="layout-fixed sidebar-expand-lg bg-body-tertiary">
    <!--begin::App Wrapper-->
    <div class="app-wrapper">
      <Topbar path={path} />
      <Sidenav path={path} mainPage={mainPage} page={page} />
      <!--begin::App Main-->
      <main class="app-main">
        <!--begin::App Content Header-->
        <div class="app-content-header">
          <div class="container-fluid">
            <div class="row">
              <div class="col-sm-6">
                <h3 class="mb-0">Báo cáo Thống kê</h3>
              </div>
              <div class="col-sm-6">
                <ol class="breadcrumb float-sm-end">
                  <li class="breadcrumb-item"><a href="#">Admin</a></li>
                  <li class="breadcrumb-item active" aria-current="page">Dashboard</li>
                </ol>
              </div>
            </div>
          </div>
        </div>
        <!--end::App Content Header-->
        <!--begin::App Content-->
        <div class="app-content">
          <div class="container-fluid">
            <!--begin::Row (Small Boxes)-->
            <div class="row">
              <div class="col-lg-3 col-6">
                <!-- Small Box 1 -->
                <div class="small-box text-bg-primary">
                  <div class="inner">
                    <h3 id="box-revenue">0đ</h3>
                    <p>Doanh Thu Tổng</p>
                  </div>
                  <i class="small-box-icon bi bi-cash-stack"></i>
                  <a href="./orders.html" class="small-box-footer link-light link-underline-opacity-0">
                    Chi tiết đơn hàng <i class="bi bi-arrow-right"></i>
                  </a>
                </div>
              </div>
              <div class="col-lg-3 col-6">
                <!-- Small Box 2 -->
                <div class="small-box text-bg-warning">
                  <div class="inner">
                    <h3 id="box-pending-orders">0</h3>
                    <p>Đơn Hàng Mới Chờ Duyệt</p>
                  </div>
                  <i class="small-box-icon bi bi-cart-fill"></i>
                  <a href="./orders.html" class="small-box-footer link-dark link-underline-opacity-0">
                    Xem hàng đợi <i class="bi bi-arrow-right"></i>
                  </a>
                </div>
              </div>
              <div class="col-lg-3 col-6">
                <!-- Small Box 3 -->
                <div class="small-box text-bg-success">
                  <div class="inner">
                    <h3 id="box-products">0</h3>
                    <p>Sản Phẩm Đang Bán</p>
                  </div>
                  <i class="small-box-icon bi bi-box-seam-fill"></i>
                  <a href="./products.html" class="small-box-footer link-light link-underline-opacity-0">
                    Quản lý sản phẩm <i class="bi bi-arrow-right"></i>
                  </a>
                </div>
              </div>
              <div class="col-lg-3 col-6">
                <!-- Small Box 4 -->
                <div class="small-box text-bg-danger">
                  <div class="inner">
                    <h3 id="box-customers">0</h3>
                    <p>Khách Hàng Đăng Ký</p>
                  </div>
                  <i class="small-box-icon bi bi-people-fill"></i>
                  <a href="./customers.html" class="small-box-footer link-light link-underline-opacity-0">
                    Xem khách hàng <i class="bi bi-arrow-right"></i>
                  </a>
                </div>
              </div>
            </div>
            <!--end::Row-->
            
            <!--begin::Row (Charts)-->
            <div class="row">
              <div class="col-lg-7">
                <div class="card mb-4 shadow-sm border-0">
                  <div class="card-header border-0 bg-transparent">
                    <h3 class="card-title fw-bold">Doanh Thu Theo Thời Gian</h3>
                  </div>
                  <div class="card-body">
                    <div id="revenue-line-chart"></div>
                  </div>
                </div>
              </div>
              <div class="col-lg-5">
                <div class="card mb-4 shadow-sm border-0">
                  <div class="card-header border-0 bg-transparent">
                    <h3 class="card-title fw-bold">Phân Phối Nhóm Khách Hàng (Tiers)</h3>
                  </div>
                  <div class="card-body">
                    <div id="tiers-bar-chart"></div>
                  </div>
                </div>
              </div>
            </div>
            <!--end::Row-->

            <!--begin::Row (Recent Orders)-->
            <div class="row">
              <div class="col-12">
                <div class="card mb-4 shadow-sm border-0">
                  <div class="card-header border-0 bg-transparent">
                    <h3 class="card-title fw-bold">Đơn Hàng Chờ Xử Lý Mới Nhất</h3>
                  </div>
                  <div class="card-body p-0">
                    <div class="table-responsive">
                      <table class="table table-striped align-middle mb-0">
                        <thead class="table-light">
                          <tr>
                            <th>Mã ĐH</th>
                            <th>Khách Hàng</th>
                            <th>Số Điện Thoại</th>
                            <th>Tổng Tiền</th>
                            <th>Ngày Đặt</th>
                            <th>Trạng Thái</th>
                            <th>Hành Động</th>
                          </tr>
                        </thead>
                        <tbody id="recent-orders-table">
                          <tr>
                            <td colspan="7" class="text-center py-4 text-muted">Đang tải danh sách đơn hàng...</td>
                          </tr>
                        </tbody>
                      </table>
                    </div>
                  </div>
                </div>
              </div>
            </div>
            <!--end::Row-->

          </div>
        </div>
        <!--end::App Content-->
      </main>
      <!--end::App Main-->
      <Footer />
    </div>
    <!--end::App Wrapper-->
    
    <!--begin::Script-->
    <Scripts path={path} />

    <!-- apexcharts -->
    <script
      src="https://cdn.jsdelivr.net/npm/apexcharts@3.37.1/dist/apexcharts.min.js"
      integrity="sha256-+vh8GkaU7C9/wbSLIcwq82tQ2wTf44aOHA8HlBMwRI8="
      crossorigin="anonymous"></script>

    <script is:inline>
      document.addEventListener("DOMContentLoaded", async () => {
        const token = localStorage.getItem("admin_token");
        const BASE_URL = window.location.hostname === "localhost" || window.location.hostname === "127.0.0.1" 
          ? "http://localhost:8080" 
          : "";

        const headers = {
          "Authorization": `Bearer ${token}`,
          "Content-Type": "application/json"
        };

        // Fetch Dashboard Box Metrics & Table Data
        try {
          // 1. Fetch products count
          const productsRes = await fetch(`${BASE_URL}/api/products`, { headers });
          const products = await productsRes.json();
          document.getElementById("box-products").textContent = products.length;

          // 2. Fetch customers count
          const customersRes = await fetch(`${BASE_URL}/api/admin/customers`, { headers });
          const customers = await customersRes.json();
          document.getElementById("box-customers").textContent = customers.length;

          // 3. Fetch orders list
          const ordersRes = await fetch(`${BASE_URL}/api/admin/orders`, { headers });
          const orders = await ordersRes.json();

          // Calculate total revenue from DELIVERED orders, and count pending
          let totalRevenue = 0;
          let pendingCount = 0;
          const pendingOrders = [];

          orders.forEach(o => {
            if (o.status === "DELIVERED" || o.status === "Đã giao") {
              totalRevenue += o.finalAmount;
            }
            if (o.status === "PENDING" || o.status === "Chờ duyệt") {
              pendingCount++;
              pendingOrders.push(o);
            }
          });

          document.getElementById("box-revenue").textContent = totalRevenue.toLocaleString("vi-VN") + "đ";
          document.getElementById("box-pending-orders").textContent = pendingCount;

          // Render recent pending orders
          const tableBody = document.getElementById("recent-orders-table");
          tableBody.innerHTML = "";

          if (pendingOrders.length === 0) {
            tableBody.innerHTML = `<tr><td colspan="7" class="text-center py-4 text-success fw-bold">Không có đơn hàng chờ duyệt nào! 🙌</td></tr>`;
          } else {
            // Sort by id desc and take 5
            pendingOrders.sort((a,b) => b.id - a.id).slice(0, 5).forEach(o => {
              const dateStr = new Date(o.createdAt || o.date).toLocaleDateString("vi-VN", {
                month: "numeric",
                day: "numeric",
                hour: "2-digit",
                minute: "2-digit"
              });
              
              tableBody.innerHTML += `
                <tr>
                  <td><strong class="text-primary">TT-${o.id}</strong></td>
                  <td>${o.fullName}</td>
                  <td>${o.phone}</td>
                  <td class="fw-bold">${o.finalAmount.toLocaleString("vi-VN")}đ</td>
                  <td>${dateStr}</td>
                  <td><span class="badge text-bg-warning">Chờ duyệt</span></td>
                  <td>
                    <a href="./orders.html" class="btn btn-sm btn-outline-primary py-0 px-2">Xử lý</a>
                  </td>
                </tr>
              `;
            });
          }

          // 4. Render Revenue Chart & Customer Tier Chart with real API stats
          // Let's call /api/admin/reports/revenue (returns list of daily revenue objects)
          // Since we might not have reports API or we want to construct dynamically:
          // We can group all orders by date
          const dailyRevenue = {};
          const tierCounts = { "BRONZE": 0, "VIP": 0, "SILVER": 0, "GOLD": 0, "PLATINUM": 0 };

          // Group revenue by date
          orders.forEach(o => {
            if (o.status === "DELIVERED" || o.status === "Đã giao") {
              const d = new Date(o.createdAt || o.date).toISOString().split('T')[0];
              dailyRevenue[d] = (dailyRevenue[d] || 0) + o.finalAmount;
            }
          });

          // Tally tiers
          customers.forEach(c => {
            const tierName = c.tier ? c.tier.name : "BRONZE";
            tierCounts[tierName] = (tierCounts[tierName] || 0) + 1;
          });

          // Sort daily revenue dates
          const sortedDates = Object.keys(dailyRevenue).sort();
          const revenueData = sortedDates.map(d => dailyRevenue[d]);

          // Fallbacks if empty
          const chartDates = sortedDates.length > 0 ? sortedDates : [new Date().toISOString().split('T')[0]];
          const chartRevenue = revenueData.length > 0 ? revenueData : [0];

          // Render charts
          const lineOptions = {
            series: [{
              name: 'Doanh thu (VND)',
              data: chartRevenue
            }],
            chart: {
              height: 300,
              type: 'area',
              toolbar: { show: false }
            },
            colors: ['#0d6efd'],
            stroke: { curve: 'smooth' },
            xaxis: {
              type: 'datetime',
              categories: chartDates
            },
            yaxis: {
              labels: {
                formatter: (val) => val.toLocaleString("vi-VN") + "đ"
              }
            }
          };
          new ApexCharts(document.querySelector("#revenue-line-chart"), lineOptions).render();

          const barOptions = {
            series: [{
              name: 'Số lượng khách hàng',
              data: [
                tierCounts["BRONZE"] || 0,
                tierCounts["VIP"] || 0,
                tierCounts["SILVER"] || 0,
                tierCounts["GOLD"] || 0,
                tierCounts["PLATINUM"] || 0
              ]
            }],
            chart: {
              type: 'bar',
              height: 300,
              toolbar: { show: false }
            },
            plotOptions: {
              bar: {
                borderRadius: 4,
                horizontal: false,
                columnWidth: '40%'
              }
            },
            xaxis: {
              categories: ['Đồng', 'VIP', 'Bạc', 'Vàng', 'Bạch kim']
            },
            colors: ['#ffc107']
          };
          new ApexCharts(document.querySelector("#tiers-bar-chart"), barOptions).render();

        } catch (err) {
          console.error("Lỗi đồng bộ báo cáo:", err);
        }
      });
    </script>
  </body><!--end::Body-->
</html>
