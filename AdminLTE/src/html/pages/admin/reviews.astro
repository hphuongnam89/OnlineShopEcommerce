---
import Head from "@components/_head.astro"
import Footer from "@components/dashboard/_footer.astro"
import Topbar from "@components/dashboard/_topbar.astro"
import Sidenav from "@components/dashboard/_sidenav.astro"
import Scripts from "@components/_scripts.astro"

const title = "Think Tank | Quản lý Đánh giá"
const path = "../dist"
const mainPage = "admin"
const page = "reviews"
---

<!doctype html>
<html lang="en">
  <!--begin::Head-->
  <head>
    <Head title={title} path={path} />
    <script is:inline>
      // Auth Guard
      if (!localStorage.getItem("admin_token")) {
        window.location.href = "./login.html";
      }
    </script>
  </head>
  <!--end::Head-->
  <!--begin::Body-->
  <body class="layout-fixed sidebar-expand-lg bg-body-tertiary">
    <!--begin::App Wrapper-->
    <div class="app-wrapper">
      <Topbar path={path} />
      <Sidenav path={path} mainPage={mainPage} page={page} />
      <!--begin::App Main-->
      <main class="app-main">
        <!--begin::App Content Header-->
        <div class="app-content-header">
          <div class="container-fluid">
            <div class="row">
              <div class="col-sm-6">
                <h3 class="mb-0">Quản lý Đánh giá</h3>
              </div>
              <div class="col-sm-6">
                <ol class="breadcrumb float-sm-end">
                  <li class="breadcrumb-item"><a href="./index.html">Admin</a></li>
                  <li class="breadcrumb-item active" aria-current="page">Đánh giá</li>
                </ol>
              </div>
            </div>
          </div>
        </div>
        <!--end::App Content Header-->
        <!--begin::App Content-->
        <div class="app-content">
          <div class="container-fluid">
            
            <!-- Alert message -->
            <div id="alert-box" class="alert alert-dismissible fade show d-none" role="alert">
              <span id="alert-message"></span>
              <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>

            <!-- Filters -->
            <div class="card mb-4 shadow-sm border-0">
              <div class="card-body">
                <div class="row g-3 align-items-center">
                  <!-- Search Keyword -->
                  <div class="col-md-5">
                    <div class="input-group">
                      <span class="input-group-text bg-transparent border-end-0 text-muted">
                        <i class="bi bi-search"></i>
                      </span>
                      <input
                        type="text"
                        id="filter-search"
                        class="form-control border-start-0"
                        placeholder="Tìm kiếm theo nhận xét hoặc sản phẩm..."
                      />
                    </div>
                  </div>
                  <!-- Rating Filter -->
                  <div class="col-md-4">
                    <select id="filter-rating" class="form-select">
                      <option value="">Tất cả mức đánh giá</option>
                      <option value="5">⭐⭐⭐⭐⭐ (5 sao)</option>
                      <option value="4">⭐⭐⭐⭐ (4 sao)</option>
                      <option value="3">⭐⭐⭐ (3 sao)</option>
                      <option value="2">⭐⭐ (2 sao)</option>
                      <option value="1">⭐ (1 sao)</option>
                    </select>
                  </div>
                  <!-- Filter Buttons -->
                  <div class="col-md-3">
                    <button id="btn-filter" class="btn btn-primary px-4">
                      <i class="bi bi-funnel-fill"></i> Lọc
                    </button>
                    <button id="btn-reset" class="btn btn-outline-secondary ms-2">
                      Làm mới
                    </button>
                  </div>
                </div>
              </div>
            </div>

            <!-- Reviews Table -->
            <div class="card shadow-sm border-0 mb-4">
              <div class="card-body p-0">
                <div class="table-responsive">
                  <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                      <tr>
                        <th width="80">Mã ĐG</th>
                        <th width="250">Sản phẩm</th>
                        <th width="150">Khách hàng</th>
                        <th width="120" class="text-center">Số sao</th>
                        <th>Bình luận nhận xét</th>
                        <th width="120" class="text-center">Ngày gửi</th>
                        <th class="text-end" width="100">Hành động</th>
                      </tr>
                    </thead>
                    <tbody id="reviews-table-body">
                      <tr>
                        <td colspan="7" class="text-center py-5 text-muted">
                          <div class="spinner-border spinner-border-sm text-primary me-2" role="status"></div>
                          Đang tải danh sách đánh giá...
                        </td>
                      </tr>
                    </tbody>
                  </table>
                </div>
              </div>
              <div class="card-footer bg-transparent border-top-0 d-flex justify-content-between align-items-center py-3">
                <div class="text-muted small" id="reviews-count-info">
                  Tìm thấy 0 đánh giá
                </div>
              </div>
            </div>

          </div>
        </div>
        <!--end::App Content-->
      </main>
      <!--end::App Main-->
      <Footer />
    </div>
    <!--end::App Wrapper-->

    <!--begin::Script-->
    <Scripts path={path} />

    <script is:inline>
      document.addEventListener("DOMContentLoaded", async () => {
        const token = localStorage.getItem("admin_token");
        const BASE_URL = window.location.hostname === "localhost" || window.location.hostname === "127.0.0.1" 
          ? "http://localhost:8080" 
          : "";

        const headers = {
          "Authorization": `Bearer ${token}`,
          "Content-Type": "application/json"
        };

        let rawReviews = [];

        // Stars generator
        function getStarsHtml(rating) {
          let html = '<span class="text-warning fw-bold">';
          for (let i = 1; i <= 5; i++) {
            if (i <= rating) {
              html += '★';
            } else {
              html += '<span class="text-muted">☆</span>';
            }
          }
          html += `</span> <span class="small font-monospace text-secondary">(${rating})</span>`;
          return html;
        }

        // Alert Helper
        function showAlert(msg, type = "success") {
          const alertBox = document.getElementById("alert-box");
          const alertMsg = document.getElementById("alert-message");
          alertBox.className = `alert alert-${type} alert-dismissible fade show`;
          alertMsg.textContent = msg;
          alertBox.classList.remove("d-none");
          setTimeout(() => {
            alertBox.classList.add("d-none");
          }, 4000);
        }

        // Fetch and Render Reviews
        async function fetchReviews() {
          const tbody = document.getElementById("reviews-table-body");
          tbody.innerHTML = `
            <tr>
              <td colspan="7" class="text-center py-5 text-muted">
                <div class="spinner-border spinner-border-sm text-primary me-2" role="status"></div>
                Đang tải danh sách đánh giá...
              </td>
            </tr>
          `;

          try {
            const res = await fetch(`${BASE_URL}/api/admin/reviews`, { headers });
            if (!res.ok) throw new Error("Không thể tải danh sách đánh giá");
            rawReviews = await res.json();
            
            renderReviewsTable();
          } catch (err) {
            console.error(err);
            tbody.innerHTML = `<tr><td colspan="7" class="text-center py-5 text-danger fw-bold">Không kết nối được với Server!</td></tr>`;
          }
        }

        // Local filter and render
        function renderReviewsTable() {
          const search = document.getElementById("filter-search").value.toLowerCase().trim();
          const ratingFilter = document.getElementById("filter-rating").value;

          const filtered = rawReviews.filter(rev => {
            const matchesRating = !ratingFilter || rev.rating == ratingFilter;
            
            const pName = (rev.product ? rev.product.name : "").toLowerCase();
            const comment = (rev.comment || "").toLowerCase();
            const uName = (rev.user ? rev.user.fullName : "").toLowerCase();
            const matchesSearch = !search || 
                                  pName.includes(search) || 
                                  comment.includes(search) ||
                                  uName.includes(search);
            
            return matchesRating && matchesSearch;
          });

          // Sort reviews descending by ID (newest first)
          filtered.sort((a,b) => b.id - a.id);

          const tbody = document.getElementById("reviews-table-body");
          tbody.innerHTML = "";

          if (filtered.length === 0) {
            tbody.innerHTML = `<tr><td colspan="7" class="text-center py-5 text-muted">Không tìm thấy đánh giá nào!</td></tr>`;
            document.getElementById("reviews-count-info").textContent = "Tìm thấy 0 đánh giá";
            return;
          }

          filtered.forEach(rev => {
            const p = rev.product || {};
            const u = rev.user || {};
            const dateStr = rev.createdAt ? new Date(rev.createdAt).toLocaleDateString("vi-VN") : "N/A";
            
            tbody.innerHTML += `
              <tr>
                <td><strong>DG-${rev.id}</strong></td>
                <td>
                  <div class="d-flex align-items-center">
                    <img src="${p.imageUrl || 'https://placehold.co/80'}" class="img-thumbnail rounded me-2" style="width: 40px; height: 40px; object-fit: contain;" />
                    <div class="text-truncate" style="max-width: 200px;">
                      <a href="/product/${p.id}" target="_blank" class="fw-bold text-decoration-none text-dark">${p.name || 'Sản phẩm đã xóa'}</a>
                    </div>
                  </div>
                </td>
                <td>
                  <div class="fw-bold">${u.fullName || 'Khách ẩn danh'}</div>
                  <div class="text-muted small">${u.email || ''}</div>
                </td>
                <td class="text-center">${getStarsHtml(rev.rating)}</td>
                <td><span class="font-sans">${rev.comment || '<em class="text-muted">Không có nhận xét chi tiết</em>'}</span></td>
                <td class="text-center text-muted small">${dateStr}</td>
                <td class="text-end">
                  <button class="btn btn-sm btn-outline-danger btn-delete-review" data-id="${rev.id}"><i class="bi bi-trash"></i> Xóa</button>
                </td>
              </tr>
            `;
          });

          document.getElementById("reviews-count-info").textContent = `Tìm thấy ${filtered.length} đánh giá`;
        }

        // Delete Review
        async function deleteReview(id) {
          try {
            const res = await fetch(`${BASE_URL}/api/admin/reviews/${id}`, {
              method: "DELETE",
              headers
            });

            if (!res.ok) throw new Error("Lỗi khi xóa đánh giá!");

            showAlert("Đã xóa đánh giá thành công!", "danger");
            fetchReviews();
          } catch (err) {
            alert(err.message);
          }
        }

        // Delete click handler
        document.getElementById("reviews-table-body").addEventListener("click", (e) => {
          const btnDel = e.target.closest(".btn-delete-review");
          if (btnDel) {
            const id = btnDel.getAttribute("data-id");
            if (confirm("Bạn có chắc chắn muốn xóa đánh giá này không? Mức điểm trung bình của sản phẩm sẽ được tính toán lại.")) {
              deleteReview(id);
            }
          }
        });

        // Trigger filters
        document.getElementById("btn-filter").addEventListener("click", () => {
          renderReviewsTable();
        });

        document.getElementById("btn-reset").addEventListener("click", () => {
          document.getElementById("filter-search").value = "";
          document.getElementById("filter-rating").value = "";
          renderReviewsTable();
        });

        // Initial fetch
        await fetchReviews();
      });
    </script>
  </body><!--end::Body-->
</html>
