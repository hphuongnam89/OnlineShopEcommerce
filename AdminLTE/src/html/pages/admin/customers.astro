---
import Head from "@components/_head.astro"
import Footer from "@components/dashboard/_footer.astro"
import Topbar from "@components/dashboard/_topbar.astro"
import Sidenav from "@components/dashboard/_sidenav.astro"
import Scripts from "@components/_scripts.astro"

const title = "Think Tank | Quản lý Khách hàng"
const path = "../dist"
const mainPage = "admin"
const page = "customers"
---

<!doctype html>
<html lang="en">
  <!--begin::Head-->
  <head>
    <Head title={title} path={path} />
    <script is:inline>
      // Auth Guard
      if (!localStorage.getItem("admin_token")) {
        window.location.href = "./login.html";
      }
    </script>
  </head>
  <!--end::Head-->
  <!--begin::Body-->
  <body class="layout-fixed sidebar-expand-lg bg-body-tertiary">
    <!--begin::App Wrapper-->
    <div class="app-wrapper">
      <Topbar path={path} />
      <Sidenav path={path} mainPage={mainPage} page={page} />
      <!--begin::App Main-->
      <main class="app-main">
        <!--begin::App Content Header-->
        <div class="app-content-header">
          <div class="container-fluid">
            <div class="row">
              <div class="col-sm-6">
                <h3 class="mb-0">Quản lý Khách hàng</h3>
              </div>
              <div class="col-sm-6">
                <ol class="breadcrumb float-sm-end">
                  <li class="breadcrumb-item"><a href="./index.html">Admin</a></li>
                  <li class="breadcrumb-item active" aria-current="page">Khách hàng</li>
                </ol>
              </div>
            </div>
          </div>
        </div>
        <!--end::App Content Header-->
        <!--begin::App Content-->
        <div class="app-content">
          <div class="container-fluid">
            
            <!-- Filters & Actions -->
            <div class="card mb-4 shadow-sm border-0">
              <div class="card-body">
                <div class="row g-3 align-items-center">
                  <!-- Search Keyword -->
                  <div class="col-md-3">
                    <label for="filter-search" class="form-label fw-bold small text-secondary">Tìm kiếm</label>
                    <input
                      type="text"
                      id="filter-search"
                      class="form-control"
                      placeholder="Tên, số điện thoại, email..."
                    />
                  </div>
                  <!-- Tier Filter -->
                  <div class="col-md-2">
                    <label for="filter-tier" class="form-label fw-bold small text-secondary">Hạng thành viên</label>
                    <select id="filter-tier" class="form-select">
                      <option value="">Tất cả hạng</option>
                      <option value="1">Bronze (Đồng)</option>
                      <option value="2">VIP (VIP)</option>
                      <option value="3">Silver (Bạc)</option>
                      <option value="4">Gold (Vàng)</option>
                      <option value="5">Platinum (Bạch kim)</option>
                    </select>
                  </div>
                  <!-- Min Spent -->
                  <div class="col-md-2">
                    <label for="filter-min-spent" class="form-label fw-bold small text-secondary">Chi tiêu tối thiểu (đ)</label>
                    <input
                      type="number"
                      id="filter-min-spent"
                      class="form-control"
                      placeholder="0"
                    />
                  </div>
                  <!-- Max Spent -->
                  <div class="col-md-2">
                    <label for="filter-max-spent" class="form-label fw-bold small text-secondary">Chi tiêu tối đa (đ)</label>
                    <input
                      type="number"
                      id="filter-max-spent"
                      class="form-control"
                      placeholder="100,000,000"
                    />
                  </div>
                  <!-- Buttons -->
                  <div class="col-md-3 text-end pt-4">
                    <button id="btn-filter" class="btn btn-primary px-3">
                      <i class="bi bi-funnel-fill"></i> Lọc
                    </button>
                    <button id="btn-export-excel" class="btn btn-success ms-2 px-3">
                      <i class="bi bi-file-earmark-excel-fill"></i> Xuất Excel
                    </button>
                  </div>
                </div>
              </div>
            </div>

            <!-- Customer List Table -->
            <div class="card shadow-sm border-0 mb-4">
              <div class="card-body p-0">
                <div class="table-responsive">
                  <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                      <tr>
                        <th width="80">Mã KH</th>
                        <th>Họ và tên</th>
                        <th>Email</th>
                        <th>Số điện thoại</th>
                        <th class="text-end">Tổng chi tiêu</th>
                        <th class="text-center">Hạng thẻ</th>
                        <th class="text-center">Ngày tham gia</th>
                      </tr>
                    </thead>
                    <tbody id="customers-table-body">
                      <tr>
                        <td colspan="7" class="text-center py-5 text-muted">
                          <div class="spinner-border spinner-border-sm text-primary me-2" role="status"></div>
                          Đang tải danh sách khách hàng...
                        </td>
                      </tr>
                    </tbody>
                  </table>
                </div>
              </div>
              <div class="card-footer bg-transparent border-top-0 d-flex justify-content-between align-items-center py-3">
                <div class="text-muted small" id="customer-count-info">
                  Tìm thấy 0 khách hàng phù hợp
                </div>
              </div>
            </div>

          </div>
        </div>
        <!--end::App Content-->
      </main>
      <!--end::App Main-->
      <Footer />
    </div>
    <!--end::App Wrapper-->

    <!--begin::Script-->
    <Scripts path={path} />

    <script is:inline>
      document.addEventListener("DOMContentLoaded", async () => {
        const token = localStorage.getItem("admin_token");
        const BASE_URL = window.location.hostname === "localhost" || window.location.hostname === "127.0.0.1" 
          ? "http://localhost:8080" 
          : "";

        const headers = {
          "Authorization": `Bearer ${token}`,
          "Content-Type": "application/json"
        };

        // Render Tier Badges
        function getTierBadgeHtml(tierName) {
          switch (tierName) {
            case "PLATINUM":
              return `<span class="badge text-bg-dark border border-secondary" style="background: linear-gradient(135deg, #e5e4e2, #b4b4b4) !important; color: #111 !important; font-weight: bold;"><i class="bi bi-gem"></i> Bạch kim</span>`;
            case "GOLD":
              return `<span class="badge text-bg-warning" style="background: linear-gradient(135deg, #ffd700, #ffa500) !important; color: #000 !important; font-weight: bold;"><i class="bi bi-award-fill"></i> Vàng</span>`;
            case "SILVER":
              return `<span class="badge text-bg-light border" style="background: linear-gradient(135deg, #e0e0e0, #f5f5f5) !important; color: #555 !important; font-weight: bold;"><i class="bi bi-shield-fill"></i> Bạc</span>`;
            case "VIP":
              return `<span class="badge text-bg-danger" style="background: linear-gradient(135deg, #dc3545, #b02a37) !important; font-weight: bold;"><i class="bi bi-star-fill"></i> VIP</span>`;
            default:
              return `<span class="badge text-bg-secondary" style="background: linear-gradient(135deg, #cd7f32, #a0522d) !important; font-weight: bold;"><i class="bi bi-person"></i> Đồng (Bronze)</span>`;
          }
        }

        // Fetch and Render Customers list
        async function loadCustomers() {
          const search = document.getElementById("filter-search").value.trim();
          const tierId = document.getElementById("filter-tier").value;
          const minSpent = document.getElementById("filter-min-spent").value;
          const maxSpent = document.getElementById("filter-max-spent").value;

          const query = new URLSearchParams();
          if (search) query.append("search", search);
          if (tierId) query.append("tierId", tierId);
          if (minSpent) query.append("minSpent", minSpent);
          if (maxSpent) query.append("maxSpent", maxSpent);

          const tbody = document.getElementById("customers-table-body");
          tbody.innerHTML = `
            <tr>
              <td colspan="7" class="text-center py-5 text-muted">
                <div class="spinner-border spinner-border-sm text-primary me-2" role="status"></div>
                Đang tải danh sách khách hàng...
              </td>
            </tr>
          `;

          try {
            const res = await fetch(`${BASE_URL}/api/admin/customers?${query.toString()}`, { headers });
            if (!res.ok) throw new Error("Không thể tải danh sách khách hàng");
            const customers = await res.json();
            
            tbody.innerHTML = "";

            if (customers.length === 0) {
              tbody.innerHTML = `<tr><td colspan="7" class="text-center py-5 text-muted">Không tìm thấy khách hàng nào!</td></tr>`;
              document.getElementById("customer-count-info").textContent = "Tìm thấy 0 khách hàng phù hợp";
              return;
            }

            customers.forEach(c => {
              const u = c.user || {};
              const name = u.fullName || "Khách mua nhanh";
              const email = u.email || "N/A";
              const phone = u.phone || c.phone || "N/A";
              const spent = c.totalSpent || 0;
              const dateStr = c.createdAt ? new Date(c.createdAt).toLocaleDateString("vi-VN") : "N/A";
              const tierName = c.tier ? c.tier.name : "BRONZE";

              tbody.innerHTML += `
                <tr>
                  <td><strong>KH-${c.id}</strong></td>
                  <td><div class="fw-bold">${name}</div></td>
                  <td><code class="text-dark">${email}</code></td>
                  <td><span class="font-monospace">${phone}</span></td>
                  <td class="text-end fw-bold text-success">${spent.toLocaleString("vi-VN")}đ</td>
                  <td class="text-center">${getTierBadgeHtml(tierName)}</td>
                  <td class="text-center text-muted small">${dateStr}</td>
                </tr>
              `;
            });

            document.getElementById("customer-count-info").textContent = `Tìm thấy ${customers.length} khách hàng phù hợp`;
          } catch (err) {
            console.error(err);
            tbody.innerHTML = `<tr><td colspan="7" class="text-center py-5 text-danger fw-bold">Lỗi đồng bộ dữ liệu với Server!</td></tr>`;
          }
        }

        // Export Excel Action with JWT Headers
        document.getElementById("btn-export-excel").addEventListener("click", async () => {
          const search = document.getElementById("filter-search").value.trim();
          const tierId = document.getElementById("filter-tier").value;
          const minSpent = document.getElementById("filter-min-spent").value;
          const maxSpent = document.getElementById("filter-max-spent").value;

          const query = new URLSearchParams();
          if (search) query.append("search", search);
          if (tierId) query.append("tierId", tierId);
          if (minSpent) query.append("minSpent", minSpent);
          if (maxSpent) query.append("maxSpent", maxSpent);

          const exportBtn = document.getElementById("btn-export-excel");
          const originalHtml = exportBtn.innerHTML;
          exportBtn.disabled = true;
          exportBtn.innerHTML = `<span class="spinner-border spinner-border-sm me-2" role="status"></span> Đang xuất...`;

          try {
            const res = await fetch(`${BASE_URL}/api/admin/reports/export/customers?${query.toString()}`, {
              headers
            });

            if (!res.ok) throw new Error("Lỗi khi kết xuất file Excel!");

            const blob = await res.blob();
            const downloadUrl = window.URL.createObjectURL(blob);
            const a = document.createElement("a");
            a.href = downloadUrl;
            a.download = `Danh_Sach_Khach_Hang_${new Date().toISOString().split('T')[0]}.xlsx`;
            document.body.appendChild(a);
            a.click();
            a.remove();
          } catch (err) {
            alert(err.message);
          } finally {
            exportBtn.disabled = false;
            exportBtn.innerHTML = originalHtml;
          }
        });

        // Trigger filters
        document.getElementById("btn-filter").addEventListener("click", () => {
          loadCustomers();
        });

        // Initial load
        await loadCustomers();
      });
    </script>
  </body><!--end::Body-->
</html>
